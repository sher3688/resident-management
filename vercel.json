{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": { "nodeVersion": "20.x" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/index.js" }
  ]
}
