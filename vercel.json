{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/static",
  "installCommand": "pnpm install",
  "builds": [
    {
      "src": "dist/functions/api/index.cjs",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/__manus__/(.*)", "destination": "/__manus__/$1" },
    { "source": "/pdf.worker.min.mjs", "destination": "/pdf.worker.min.mjs" },
    { "source": "/api/(.*)", "destination": "dist/functions/api/index.cjs" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
